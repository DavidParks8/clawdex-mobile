{
  "name": "@tethercode/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node scripts/run-expo.cjs start",
    "ios": "node scripts/run-expo.cjs run:ios",
    "android": "node scripts/run-expo.cjs run:android",
    "lint": "eslint App.tsx src --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/run-expo.cjs export --platform all --output-dir dist",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --runInBand --coverage",
    "test:contract": "jest --runInBand src/api/__tests__/contractFixtures.test.ts",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@ag-ui/core": "0.0.57",
    "@expo-google-fonts/fira-code": "^0.4.1",
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/source-code-pro": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "15.0.3",
    "expo": "~55.0.28",
    "expo-blur": "~55.0.10",
    "expo-camera": "~55.0.10",
    "expo-clipboard": "~55.0.9",
    "expo-crypto": "^55.0.14",
    "expo-device": "~55.0.17",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.9",
    "expo-font": "~55.0.6",
    "expo-image-manipulator": "~55.0.19",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "~55.0.9",
    "expo-store-review": "~55.0.9",
    "expo-web-browser": "^55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-markdown-display": "7.0.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "^22.19.15",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "resolve-from": "5.0.0",
    "typescript": "7.0.2",
    "typescript-expo-compat": "npm:typescript@5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "App.tsx",
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**",
      "!src/screens/mainScreenStyles.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 86
      }
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ]
  }
}
